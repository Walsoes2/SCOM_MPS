  <TypeDefinitions>
    <ModuleTypes>
      <DataSourceModuleType ID="LUL.LastRebootCheck.Monitor.DataSource" Accessibility="Internal" Batching="false">
        <Configuration>
          <xsd:element minOccurs="0" name="Server" type="xsd:string" xmlns:xsd="http://www.w3.org/2001/XMLSchema" />
          <xsd:element minOccurs="1" name="IntervalBetweenCheck" type="xsd:integer" xmlns:xsd="http://www.w3.org/2001/XMLSchema" />
          <xsd:element minOccurs="1" name="LastRebootWarningThreshold" type="xsd:integer" xmlns:xsd="http://www.w3.org/2001/XMLSchema" />
          <xsd:element minOccurs="1" name="TimeoutSeconds" type="xsd:integer" xmlns:xsd="http://www.w3.org/2001/XMLSchema" />
        </Configuration>
        <OverrideableParameters>
          <OverrideableParameter ID="Server" Selector="$Config/Server$" ParameterType="string" />
          <OverrideableParameter ID="IntervalBetweenCheck" Selector="$Config/IntervalBetweenCheck$" ParameterType="int" />
          <OverrideableParameter ID="LastRebootWarningThreshold" Selector="$Config/LastRebootWarningThreshold$" ParameterType="int" />
          <OverrideableParameter ID="TimeoutSeconds" Selector="$Config/TimeoutSeconds$" ParameterType="int" />
        </OverrideableParameters>
        <ModuleImplementation Isolation="Any">
          <Composite>
            <MemberModules>
              <DataSource ID="Scheduler" TypeID="System!System.Scheduler">
                <Scheduler>
                  <SimpleReccuringSchedule>
                    <Interval Unit="Seconds">$Config/IntervalBetweenCheck$</Interval>
                  </SimpleReccuringSchedule>
                  <ExcludeDates />
                </Scheduler>
              </DataSource>
              <ProbeAction ID="PA" TypeID="Windows!Microsoft.Windows.PowerShellPropertyBagTriggerOnlyProbe">
                <ScriptName>LUL.LastRebootCheck.Monitor.DataSource.ps1</ScriptName>
                <ScriptBody>
									
        #=================================================================================
        #  Script for checking reboot threshold
        #
        param(
        $LastRebootWarningThreshold
        )
        
        # Constants section
        $server = $env:COMPUTERNAME
        $ScriptName = "LUL.LastRebootCheck.Monitor.DataSource.ps1"
        $EventID = "50001"
        
        # Gather start time of script
        $StartTime = Get-Date
        $whoami = whoami
        $momapi = New-Object -comObject MOM.ScriptAPI
        $bag = $momapi.CreatePropertyBag()
        
        # Check Uptime
        $LastBootUpTime = (Get-CimInstance Win32_OperatingSystem).LastBootUpTime
        $UptimeInDays = [math]::Round(($StartTime - $LastBootUpTime).TotalDays)

        if ($UptimeInDays -ge $LastRebootWarningThreshold) {
            $bag.AddValue('Server',$server)
            $bag.AddValue('Result',"BadCondition")
            $bag.AddValue('LastBootUpTime',$LastBootUpTime)
            $bag.AddValue('Message',"Server has not rebooted in $UptimeInDays days.")
        } else {
            $bag.AddValue('Server',$server)
            $bag.AddValue('Result',"GoodCondition")
            $bag.AddValue('LastBootUpTime',$LastBootUpTime)
            $bag.AddValue('Message',"Server rebooted within $UptimeInDays days.")
        }
        
        # Return PropertyBag
        return $bag
        
								</ScriptBody>
                <Parameters>
                  <Parameter>
                    <Name>LastRebootWarningThreshold</Name>
                    <Value>$Config/LastRebootWarningThreshold$</Value>
                  </Parameter>
                </Parameters>
                <TimeoutSeconds>$Config/TimeoutSeconds$</TimeoutSeconds>
              </ProbeAction>
            </MemberModules>
            <Composition>
              <Node ID="PA">
                <Node ID="Scheduler" />
              </Node>
            </Composition>
          </Composite>
        </ModuleImplementation>
        <OutputType>System!System.PropertyBagData</OutputType>
      </DataSourceModuleType>
    </ModuleTypes>
